# Server
PORT=8787
BASE_URL=http://localhost:8787

# Optional shared secret for ChatGPT Actions or internal clients.
# If set, pass Authorization: Bearer <APP_SHARED_SECRET> or x-api-key: <APP_SHARED_SECRET>.
APP_SHARED_SECRET=

# OpenAI-compatible Chat Completions endpoint.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions

# Alibaba TOP / ICBU Open API
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
ALIBABA_ACCESS_TOKEN=
ALIBABA_GATEWAY=https://eco.taobao.com/router/rest
ALIBABA_SELF_ACCOUNT_ID=
